{
  "name": "@gvorax/pdf-editor",
  "version": "1.0.3",
  "description": "Angular PDF editor library with annotation support (pen, highlighter, shapes, text, eraser)",
  "keywords": [
    "angular",
    "pdf",
    "editor",
    "annotation",
    "fabric",
    "pdfjs"
  ],
  "author": "gvorax",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/gvorax/pdf-editor.git"
  },
  "homepage": "https://github.com/gvorax/pdf-editor",
  "bugs": {
    "url": "https://github.com/gvorax/pdf-editor/issues"
  },
  "packageManager": "npm@11.11.0",
  "peerDependencies": {
    "@angular/common": ">=17.0.0",
    "@angular/core": ">=17.0.0",
    "@angular/platform-browser": ">=17.0.0",
    "fabric": ">=6.0.0",
    "pdf-lib": ">=1.0.0",
    "pdfjs-dist": ">=4.0.0"
  },
  "module": "fesm2022/gvorax-pdf-editor.mjs",
  "typings": "types/gvorax-pdf-editor.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/gvorax-pdf-editor.d.ts",
      "default": "./fesm2022/gvorax-pdf-editor.mjs"
    }
  },
  "sideEffects": false,
  "type": "module",
  "dependencies": {
    "tslib": "^2.3.0"
  }
}