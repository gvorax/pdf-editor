{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/lib",
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "experimentalDecorators": false,
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "include": [
    "src/lib/**/*.ts"
  ],
  "exclude": [
    "src/app/**",
    "src/**/*.spec.ts",
    "src/main.ts"
  ]
}
